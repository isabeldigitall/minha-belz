# === O TEU NOME ===
# Como queres que a tua assistente te trate
OWNER_NAME=Maria

# === TELEGRAM ===
# Token do bot (cria em @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=

# === GEMINI ===
# API key do Gemini (cria em https://aistudio.google.com/apikey)
# IMPORTANTE: tem de estar num projeto Google Cloud com billing ativado
GEMINI_API_KEY=

# === GOOGLE OAUTH (Calendar + Drive) ===
# Cria em Google Cloud Console -> APIs e Servicos -> Credenciais -> OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email da conta Google que vai usar (calendar e drive)
GOOGLE_EMAIL=

# Fuso horario (ex: Europe/Lisbon, America/Sao_Paulo, Europe/London)
TIMEZONE=Europe/Lisbon

# === BRIEFING MATINAL ===
# Hora (formato 24h) a que queres receber o resumo do dia
BRIEFING_HOUR=8

# === OPCIONAL: PORTA HTTP ===
# Apenas usado se quiseres expor health check (deploy em VPS)
PORT=3000
